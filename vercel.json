{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/cron/auto-complete-duties.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/cron/mark-incomplete-duties.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://hospilink-frontend-ten.vercel.app" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,PATCH,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,Accept,X-Requested-With,Origin,Access-Control-Request-Method,Access-Control-Request-Headers,Cache-Control" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/backend/api/cron/auto-complete-duties",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/backend/api/cron/mark-incomplete-duties",
      "schedule": "*/30 * * * *"
    }
  ]
}
