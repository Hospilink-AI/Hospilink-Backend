{
  "name": "hospilink",
  "version": "1.0.0",
  "description": "Hospital Management System",
  "main": "server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "dev:win": "set NODE_ENV=development&&nodemon server.js",
    "start:win": "set NODE_ENV=production&&node server.js",
    "agent:health": "curl -s http://localhost:3002/v1/health",
    "agent:start": "node agent/start.js",
    "agent:dev": "nodemon agent/start.js",
    "websocket": "node websocket-server.js",
    "websocket:dev": "nodemon websocket-server.js"
  },
  "keywords": [
    "hospital",
    "management",
    "healthcare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1046.0",
    "@aws-sdk/s3-request-presigner": "^3.1046.0",
    "@google-cloud/vision": "^4.3.3",
    "@google/generative-ai": "^0.21.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.9.0",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "mongoose": "^7.8.9",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.43.1",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "turndown": "^7.2.4",
    "uuid": "^9.0.1",
    "validator": "^13.15.35",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.38.0",
    "jest": "^29.5.0",
    "mongodb-memory-server": "^9.4.1",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.7"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "forceExit": true,
    "detectOpenHandles": true
  }
}
